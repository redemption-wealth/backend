generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum AdminRole {
  OWNER
  MANAGER
  ADMIN
}

enum MerchantCategory {
  kuliner
  hiburan
  event
  kesehatan
  lifestyle
  lainnya
}

enum SlotStatus {
  AVAILABLE
  REDEEMED
  FULLY_USED
}

enum RedemptionStatus {
  PENDING
  CONFIRMED
  FAILED
  EXPIRED
}

enum QrStatus {
  AVAILABLE
  REDEEMED
  USED
}

// ─── Better Auth managed tables ─────────────────────────────────────────────
// Field names must match Better Auth's expected schema exactly.

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(true)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions    Session[]
  accounts    Account[]
  admin       Admin?
  setupTokens PasswordSetupToken[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("accounts")
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@map("verifications")
}

// ─── Custom tables ───────────────────────────────────────────────────────────

model Admin {
  id          String    @id @default(cuid())
  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        AdminRole
  merchantId  String?
  merchant    Merchant? @relation(fields: [merchantId], references: [id], onDelete: SetNull)
  isActive    Boolean   @default(true)
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  scannedQrCodes QrCode[]

  @@map("admins")
}

model PasswordSetupToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@map("password_setup_tokens")
}

model Merchant {
  id          String           @id @default(cuid())
  name        String
  description String?
  logoUrl     String?
  category    MerchantCategory @default(lainnya)
  isActive    Boolean          @default(true)
  deletedAt   DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  vouchers    Voucher[]
  admins      Admin[]
  redemptions Redemption[]

  @@map("merchants")
}

model AppSettings {
  id           String   @id @default("singleton")
  appFeeRate   Decimal  @default(3.00) @db.Decimal(5, 2)
  gasFeeAmount Decimal  @default(0)    @db.Decimal(15, 2)
  updatedAt    DateTime @updatedAt

  @@map("app_settings")
}

model Voucher {
  id             String           @id @default(cuid())
  merchantId     String
  merchant       Merchant         @relation(fields: [merchantId], references: [id], onDelete: Restrict)
  title          String
  description    String?
  basePrice      Decimal          @db.Decimal(15, 2)
  totalStock     Int
  remainingStock Int
  qrPerSlot      Int              @default(1)
  appFeeSnapshot Decimal          @db.Decimal(5, 2)
  gasFeeSnapshot Decimal          @db.Decimal(15, 2)
  startDate      DateTime         @db.Date
  expiryDate     DateTime         @db.Date
  isActive       Boolean          @default(true)
  deletedAt      DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  slots       RedemptionSlot[]
  qrCodes     QrCode[]
  redemptions Redemption[]

  @@map("vouchers")
}

model RedemptionSlot {
  id        String     @id @default(cuid())
  voucherId String
  voucher   Voucher    @relation(fields: [voucherId], references: [id], onDelete: Restrict)
  slotIndex Int
  status    SlotStatus @default(AVAILABLE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  qrCodes    QrCode[]
  redemption Redemption?

  @@unique([voucherId, slotIndex])
  @@map("redemption_slots")
}

model QrCode {
  id           String         @id @default(cuid())
  slotId       String
  slot         RedemptionSlot @relation(fields: [slotId], references: [id], onDelete: Restrict)
  voucherId    String
  voucher      Voucher        @relation(fields: [voucherId], references: [id], onDelete: Restrict)
  qrNumber     Int            @db.SmallInt
  token        String         @unique
  imageUrl     String?
  imageHash    String         @unique
  status       QrStatus       @default(AVAILABLE)
  redemptionId String?
  redemption   Redemption?    @relation(fields: [redemptionId], references: [id], onDelete: SetNull)
  scannedById  String?
  scannedBy    Admin?         @relation(fields: [scannedById], references: [id], onDelete: SetNull)
  usedAt       DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@unique([slotId, qrNumber])
  @@index([voucherId, status])
  @@map("qr_codes")
}

model Redemption {
  id                     String           @id @default(cuid())
  userEmail              String
  voucherId              String
  voucher                Voucher          @relation(fields: [voucherId], references: [id], onDelete: Restrict)
  merchantId             String
  merchant               Merchant         @relation(fields: [merchantId], references: [id], onDelete: Restrict)
  slotId                 String           @unique
  slot                   RedemptionSlot   @relation(fields: [slotId], references: [id], onDelete: Restrict)
  wealthAmount           Decimal          @db.Decimal(36, 18)
  priceIdrAtRedeem       Int
  wealthPriceIdrAtRedeem Decimal          @db.Decimal(18, 4)
  appFeeAmount           Decimal          @db.Decimal(36, 18)
  gasFeeAmount           Decimal          @db.Decimal(36, 18)
  txHash                 String?          @unique
  idempotencyKey         String           @unique
  status                 RedemptionStatus @default(PENDING)
  confirmedAt            DateTime?
  failedAt               DateTime?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  qrCodes QrCode[]

  @@index([userEmail, status])
  @@index([voucherId])
  @@map("redemptions")
}
