generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum AdminRole {
  OWNER
  MANAGER
  ADMIN
}

enum SlotStatus {
  AVAILABLE
  REDEEMED
  FULLY_USED
}

enum RedemptionStatus {
  PENDING
  CONFIRMED
  FAILED
  EXPIRED
}

enum QrStatus {
  AVAILABLE
  REDEEMED
  USED
}

// WP → $WEALTH conversion request lifecycle. Treasury is MANUAL: the user burns
// WP (PENDING), an admin sends $WEALTH off-system, then marks FULFILLED (or
// REJECTED, which refunds the WP). There is no on-chain send in the backend.
enum WpConversionStatus {
  PENDING
  FULFILLED
  REJECTED
}

// Manual fraud-review state for an AppUser. This is an operational label only —
// it NEVER blocks the user's earning or spending. Managers set it by hand from
// the back-office WP Fraud tab (per product decision: manual review, no
// auto-freeze). NONE = not reviewed, REVIEWING = under investigation,
// CLEARED = investigated and fine, FLAGGED = confirmed suspicious.
enum WpFraudReviewStatus {
  NONE
  REVIEWING
  CLEARED
  FLAGGED
}

// Asset format presented to the user behind a redeemed voucher unit.
enum VoucherFormat {
  QR
  CODE
  BARCODE
}

// Where the asset values come from. WEALTH_GENERATED is the original flow
// (Wealth mints a random QR token); MERCHANT_UPLOADED means the merchant
// supplied the values (verified on the merchant's own system, not via scan).
enum AssetSource {
  WEALTH_GENERATED
  MERCHANT_UPLOADED
}

// For MERCHANT_UPLOADED vouchers: how the merchant supplied the asset.
// VALUE = a code/value Wealth renders into a QR/barcode (or shows as text).
// IMAGE = a finished image file uploaded by the merchant, stored & shown as-is
// (used when the exact original barcode must be preserved, e.g. GS1).
enum AssetInputType {
  VALUE
  IMAGE
}

// ─── Better Auth managed tables ─────────────────────────────────────────────
// Field names must match Better Auth's expected schema exactly.

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(true)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions    Session[]
  accounts    Account[]
  admin       Admin?
  setupTokens PasswordSetupToken[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("accounts")
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@map("verifications")
}

// ─── Custom tables ───────────────────────────────────────────────────────────

model Admin {
  id          String    @id @default(cuid())
  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        AdminRole
  merchantId  String?
  merchant    Merchant? @relation(fields: [merchantId], references: [id], onDelete: SetNull)
  isActive    Boolean   @default(true)
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  scannedQrCodes QrCode[]

  @@map("admins")
}

model PasswordSetupToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@map("password_setup_tokens")
}

model Merchant {
  id          String           @id @default(cuid())
  name        String
  description String?
  logoUrl     String?
  category    String           @default("Lifestyle")
  isActive    Boolean          @default(true)
  deletedAt   DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  vouchers    Voucher[]
  admins      Admin[]
  redemptions Redemption[]

  @@map("merchants")
}

model AppSettings {
  id             String   @id @default("singleton")
  appFeeRate     Decimal  @default(3.00) @db.Decimal(5, 2)
  gasFeeAmount   Decimal  @default(0)    @db.Decimal(15, 2)
  // Anti-abuse: max WP that may be issued (earned) per calendar month.
  // When the running total for the month exceeds this, claim endpoints reject.
  wpMonthlyCapWp Int      @default(1000000)

  // ─── WP → $WEALTH conversion (manual treasury) ──────────────────────────────
  // Master switch — conversion endpoints reject while false.
  wpConversionEnabled Boolean @default(false)
  // Fixed admin-set exchange rate: how many WP burn for 1 $WEALTH.
  wpConversionRate    Int     @default(1000)
  // Minimum WP a user may convert in a single request.
  wpConvertMinWp      Int     @default(1000)
  // Per-user ceiling on WP converted per WIB calendar month (PENDING+FULFILLED).
  wpConvertMaxWpPerMonth Int  @default(100000)
  // Global monthly $WEALTH budget across all users (PENDING+FULFILLED this WIB
  // month must stay at or under this). Same $WEALTH type as Redemption.wealthAmount.
  wpConversionMonthlyBudgetWealth Decimal @default(10000) @db.Decimal(36, 18)

  updatedAt      DateTime @updatedAt

  @@map("app_settings")
}

model Voucher {
  id             String           @id @default(cuid())
  merchantId     String
  merchant       Merchant         @relation(fields: [merchantId], references: [id], onDelete: Restrict)
  title          String
  description    String?
  basePrice      Decimal          @db.Decimal(15, 2)
  totalStock     Int
  remainingStock Int
  qrPerSlot      Int              @default(1)
  format         VoucherFormat    @default(QR)
  assetSource    AssetSource      @default(WEALTH_GENERATED)
  assetInputType AssetInputType   @default(VALUE)
  barcodeSymbology String?        // only set when format = BARCODE (e.g. "CODE128", "EAN13")
  appFeeSnapshot Decimal          @db.Decimal(5, 2)
  gasFeeSnapshot Decimal          @db.Decimal(15, 2)
  startDate      DateTime         @db.Date
  expiryDate     DateTime         @db.Date
  isActive       Boolean          @default(true)
  deletedAt      DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  slots       RedemptionSlot[]
  qrCodes     QrCode[]
  redemptions Redemption[]

  @@map("vouchers")
}

model RedemptionSlot {
  id        String     @id @default(cuid())
  voucherId String
  voucher   Voucher    @relation(fields: [voucherId], references: [id], onDelete: Restrict)
  slotIndex Int
  status    SlotStatus @default(AVAILABLE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  qrCodes    QrCode[]
  redemption Redemption?

  @@unique([voucherId, slotIndex])
  @@map("redemption_slots")
}

model QrCode {
  id           String         @id @default(cuid())
  slotId       String
  slot         RedemptionSlot @relation(fields: [slotId], references: [id], onDelete: Restrict)
  voucherId    String
  voucher      Voucher        @relation(fields: [voucherId], references: [id], onDelete: Restrict)
  qrNumber     Int            @db.SmallInt
  token        String         @unique
  value        String?        // merchant-uploaded asset value (null for WEALTH_GENERATED)
  imageUrl     String?
  imageHash    String         @unique
  status       QrStatus       @default(AVAILABLE)
  redemptionId String?
  redemption   Redemption?    @relation(fields: [redemptionId], references: [id], onDelete: SetNull)
  scannedById  String?
  scannedBy    Admin?         @relation(fields: [scannedById], references: [id], onDelete: SetNull)
  assignedAt   DateTime?      // set when status → REDEEMED (QR handed to the user)
  usedAt       DateTime?      // set only when status → USED (scanned by merchant)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@unique([slotId, qrNumber])
  @@unique([voucherId, value])
  @@index([voucherId, status])
  @@map("qr_codes")
}

model Redemption {
  id                     String           @id @default(cuid())
  userEmail              String
  voucherId              String
  voucher                Voucher          @relation(fields: [voucherId], references: [id], onDelete: Restrict)
  merchantId             String
  merchant               Merchant         @relation(fields: [merchantId], references: [id], onDelete: Restrict)
  slotId                 String           @unique
  slot                   RedemptionSlot   @relation(fields: [slotId], references: [id], onDelete: Restrict)
  wealthAmount           Decimal          @db.Decimal(36, 18)
  priceIdrAtRedeem       Int
  wealthPriceIdrAtRedeem Decimal          @db.Decimal(18, 4)
  appFeeAmount           Decimal          @db.Decimal(36, 18)
  gasFeeAmount           Decimal          @db.Decimal(36, 18)
  txHash                 String?          @unique
  idempotencyKey         String           @unique
  status                 RedemptionStatus @default(PENDING)
  confirmedAt            DateTime?
  failedAt               DateTime?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  qrCodes QrCode[]

  @@index([userEmail, status])
  @@index([voucherId])
  @@map("redemptions")
}

// ─── WEALTH Points (WP) — Quest & Rewards ────────────────────────────────────
// End-user identity for the gamification layer. Distinct from the Better Auth
// `User` model (which is admin-only). Keyed to Privy identity (privyId).

model AppUser {
  id            String    @id @default(cuid())
  privyId       String    @unique
  email         String
  walletAddress String?
  // Editable profile fields (PATCH /api/users/me). username is unique.
  name          String?
  username      String?   @unique
  phone         String?
  avatarUrl     String?
  referralCode  String    @unique
  referredById  String?
  referredBy    AppUser?  @relation("Referrals", fields: [referredById], references: [id], onDelete: SetNull)
  referrals     AppUser[] @relation("Referrals")
  // Anti-bot gate: true once the user has ≥1 CONFIRMED on-chain redemption.
  // Redeeming WP for real rewards and paying referral bonuses require this.
  hasDeposited  Boolean   @default(false)
  qualifiedAt   DateTime?
  // Manual fraud-review label (see WpFraudReviewStatus). Operational only — does
  // NOT gate earning/spending. Set by managers from the WP Fraud tab.
  fraudReviewStatus WpFraudReviewStatus @default(NONE)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  ledger        WpLedger[]
  completions   QuestCompletion[]
  streak        CheckinStreak?
  wpRedemptions WpRedemption[]
  wpConversions WpConversion[]

  @@index([referredById])
  @@index([email])
  @@map("app_users")
}

// Append-only WP transaction log. Balance = SUM(amount). Never store a
// denormalized balance column (avoids desync).
model WpLedger {
  id        String   @id @default(cuid())
  appUserId String
  appUser   AppUser  @relation(fields: [appUserId], references: [id], onDelete: Cascade)
  amount    Int // + earn, - spend/clawback
  type      String // CHECKIN | TASK | REFERRAL_BONUS | REDEEM_SPEND | REDEEM_REFUND | CONVERT_SPEND | CONVERT_REFUND | ADMIN_ADJUST
  refType   String? // quest | referral | reward | conversion | admin
  refId     String?
  note      String?
  createdAt DateTime @default(now())

  @@index([appUserId, createdAt])
  @@index([type, createdAt])
  @@map("wp_ledger")
}

// WP → $WEALTH conversion request. The user burns WP (a CONVERT_SPEND ledger
// row) to create a PENDING conversion. An admin sends $WEALTH manually
// off-system, then marks it FULFILLED (optionally recording a txHash) or
// REJECTED (which refunds the WP via a CONVERT_REFUND ledger row). The backend
// never sends on-chain — there is no signer/private key.
model WpConversion {
  id           String             @id @default(cuid())
  appUserId    String
  appUser      AppUser            @relation(fields: [appUserId], references: [id], onDelete: Restrict)
  wpBurned     Int
  // $WEALTH owed for this conversion. Same type as Redemption.wealthAmount.
  wealthAmount Decimal            @db.Decimal(36, 18)
  // WP-per-$WEALTH rate captured at request time (snapshot of wpConversionRate).
  rate         Int
  toAddress    String
  status       WpConversionStatus @default(PENDING)
  txHash       String?
  note         String?
  fulfilledBy  String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([appUserId, createdAt])
  @@index([status, createdAt])
  @@map("wp_conversions")
}

model Quest {
  id          String   @id @default(cuid())
  key         String   @unique
  title       String
  description String?
  category    String // DAILY | SOCIAL | REDEEM | INVITE
  rewardWp    Int
  cadence     String // ONCE | DAILY
  targetCount Int      @default(1)
  actionUrl   String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  completions QuestCompletion[]

  @@map("quests")
}

model QuestCompletion {
  id        String   @id @default(cuid())
  appUserId String
  appUser   AppUser  @relation(fields: [appUserId], references: [id], onDelete: Cascade)
  questId   String
  quest     Quest    @relation(fields: [questId], references: [id], onDelete: Cascade)
  periodKey String // "once" | "2026-07-06" (WIB date for DAILY cadence)
  createdAt DateTime @default(now())

  @@unique([appUserId, questId, periodKey])
  @@map("quest_completions")
}

model CheckinStreak {
  appUserId       String    @id
  appUser         AppUser   @relation(fields: [appUserId], references: [id], onDelete: Cascade)
  currentStreak   Int       @default(0)
  lastCheckinDate DateTime? @db.Date
  updatedAt       DateTime  @updatedAt

  @@map("checkin_streaks")
}

model WpReward {
  id          String   @id @default(cuid())
  title       String
  category    String // VOUCHER | MERCH | SEMBAKO
  partnerName String?
  wpCost      Int
  stock       Int? // null = unlimited
  isActive    Boolean  @default(true)
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  redemptions WpRedemption[]

  @@map("wp_rewards")
}

model WpRedemption {
  id          String   @id @default(cuid())
  appUserId   String
  appUser     AppUser  @relation(fields: [appUserId], references: [id], onDelete: Restrict)
  rewardId    String
  reward      WpReward @relation(fields: [rewardId], references: [id], onDelete: Restrict)
  wpSpent     Int
  status      String   @default("PENDING") // PENDING | FULFILLED | REJECTED
  note        String? // internal admin note (not shown to the end user)
  // User-visible fulfillment note: a voucher code, shipping note, or any text the
  // Manager wants the end user to see when the redemption is FULFILLED.
  fulfillmentNote String?
  fulfilledBy String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status, createdAt])
  @@index([appUserId])
  @@map("wp_redemptions")
}
