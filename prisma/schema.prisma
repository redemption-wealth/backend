generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum AdminRole {
  owner
  manager
  admin
}

enum QrStatus {
  available
  assigned
  used
}

enum RedemptionStatus {
  pending
  confirmed
  failed
}

enum TransactionType {
  deposit
  withdrawal
  redeem
}

enum TransactionStatus {
  pending
  confirmed
  failed
}

// ─── Models ─────────────────────────────────────────────────────────────────

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  privyUserId   String   @unique @map("privy_user_id")
  walletAddress String?  @map("wallet_address")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  redemptions  Redemption[]
  transactions Transaction[]
  assignedQrs  QrCode[]

  @@map("users")
}

model Admin {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String?   @map("password_hash")
  role         AdminRole @default(manager)
  merchantId   String?   @map("merchant_id")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  createdMerchants Merchant[]  @relation("MerchantCreator")
  assignedMerchant Merchant?   @relation("AdminMerchantAssignment", fields: [merchantId], references: [id], onDelete: SetNull)
  scannedQrCodes   QrCode[]    @relation("QrCodeScanner")

  @@index([merchantId])
  @@map("admins")
}

model Merchant {
  id          String   @id @default(uuid())
  name        String
  logoUrl     String?  @map("logo_url")
  description String?  @db.Text
  categoryId  String   @map("category_id")
  isActive    Boolean  @default(true) @map("is_active")
  createdBy   String?  @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  creator       Admin?    @relation("MerchantCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  category      Category  @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  vouchers      Voucher[]
  assignedAdmins Admin[]  @relation("AdminMerchantAssignment")

  @@index([categoryId])
  @@map("merchants")
}

model Voucher {
  id              String   @id @default(uuid())
  merchantId      String   @map("merchant_id")
  title           String
  description     String?  @db.Text
  startDate       DateTime @map("start_date") @db.Date
  endDate         DateTime @map("end_date") @db.Date
  totalStock      Int      @map("total_stock")
  remainingStock  Int      @map("remaining_stock")
  usedStock       Int      @default(0) @map("used_stock")
  priceIdr        Int      @map("price_idr")
  qrPerRedemption Int      @default(1) @map("qr_per_redemption")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  merchant    Merchant     @relation(fields: [merchantId], references: [id], onDelete: Restrict)
  qrCodes     QrCode[]
  redemptions Redemption[]

  @@index([merchantId])
  @@map("vouchers")
}

model QrCode {
  id               String    @id @default(uuid())
  voucherId        String    @map("voucher_id")
  redemptionId     String?   @map("redemption_id")
  imageUrl         String?   @map("image_url")
  imageHash        String?   @map("image_hash")
  token            String    @unique @map("token")
  status           QrStatus  @default(available)
  assignedToUserId String?   @map("assigned_to_user_id")
  assignedAt       DateTime? @map("assigned_at")
  usedAt           DateTime? @map("used_at")
  scannedByAdminId String?   @map("scanned_by_admin_id")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  voucher      Voucher     @relation(fields: [voucherId], references: [id], onDelete: Restrict)
  assignedTo   User?       @relation(fields: [assignedToUserId], references: [id], onDelete: SetNull)
  redemption   Redemption? @relation(fields: [redemptionId], references: [id], onDelete: SetNull)
  scannedBy    Admin?      @relation("QrCodeScanner", fields: [scannedByAdminId], references: [id], onDelete: SetNull)

  @@index([voucherId, status])
  @@index([status])
  @@index([assignedToUserId])
  @@index([redemptionId])
  @@map("qr_codes")
}

model Redemption {
  id                     String           @id @default(uuid())
  userId                 String           @map("user_id")
  voucherId              String           @map("voucher_id")
  wealthAmount           Decimal          @map("wealth_amount") @db.Decimal(36, 18)
  priceIdrAtRedeem       Int              @map("price_idr_at_redeem")
  wealthPriceIdrAtRedeem Decimal          @map("wealth_price_idr_at_redeem") @db.Decimal(18, 4)
  appFeeAmount           Decimal          @map("app_fee_amount") @db.Decimal(36, 18)
  gasFeeAmount           Decimal          @default(0) @map("gas_fee_amount") @db.Decimal(36, 18)
  txHash                 String?          @unique @map("tx_hash")
  idempotencyKey         String           @unique @map("idempotency_key")
  status                 RedemptionStatus @default(pending)
  redeemedAt             DateTime         @default(now()) @map("redeemed_at")
  confirmedAt            DateTime?        @map("confirmed_at")
  createdAt              DateTime         @default(now()) @map("created_at")

  user        User         @relation(fields: [userId], references: [id], onDelete: Restrict)
  voucher     Voucher      @relation(fields: [voucherId], references: [id], onDelete: Restrict)
  qrCodes     QrCode[]
  transaction Transaction?

  @@index([userId, status])
  @@index([voucherId])
  @@map("redemptions")
}

model Transaction {
  id           String            @id @default(uuid())
  userId       String            @map("user_id")
  redemptionId String?           @unique @map("redemption_id")
  type         TransactionType
  amountWealth Decimal           @map("amount_wealth") @db.Decimal(36, 18)
  txHash       String?           @unique @map("tx_hash")
  status       TransactionStatus @default(pending)
  createdAt    DateTime          @default(now()) @map("created_at")
  confirmedAt  DateTime?         @map("confirmed_at")

  user       User        @relation(fields: [userId], references: [id], onDelete: Restrict)
  redemption Redemption? @relation(fields: [redemptionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@map("transactions")
}

model AppSettings {
  id                    String   @id @default("singleton")
  appFeePercentage      Decimal  @default(3) @map("app_fee_percentage") @db.Decimal(5, 2)
  tokenContractAddress  String?  @map("token_contract_address")
  treasuryWalletAddress String?  @map("treasury_wallet_address")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}

model FeeSetting {
  id        String   @id @default(uuid())
  label     String
  amountIdr Int      @map("amount_idr")
  isActive  Boolean  @default(false) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("fee_settings")
}

model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  merchants Merchant[]

  @@map("categories")
}
