{
  "name": "wealth-redemption-backend",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && tsc",
    "vercel-build": "prisma generate && prisma migrate deploy && tsc",
    "postinstall": "prisma generate",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "test": "vitest",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:e2e": "vitest run --project e2e",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch",
    "test:auth": "vitest run tests/integration/routes/auth.test.ts",
    "test:redemption": "vitest run tests/integration/routes/redemptions/ tests/e2e/redemption-flow.test.ts",
    "test:admin": "vitest run tests/integration/routes/admin/",
    "test:qr": "vitest run tests/integration/routes/admin/qr-codes.test.ts tests/e2e/multi-qr-flow.test.ts",
    "test:critical": "vitest run tests/integration/routes/auth.test.ts tests/integration/routes/redemptions/ tests/integration/routes/webhook.test.ts tests/e2e/"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1029.0",
    "@aws-sdk/s3-request-presigner": "^3.1029.0",
    "@hono/node-server": "^1.14.3",
    "@hono/zod-validator": "^0.7.6",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@privy-io/server-auth": "^1.32.5",
    "adm-zip": "^0.5.17",
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.6.9",
    "dotenv": "^16.5.0",
    "file-type": "^22.0.1",
    "hono": "^4.7.11",
    "jose": "^6.2.2",
    "node-cache": "^5.1.2",
    "pg": "^8.20.0",
    "qrcode": "^1.5.4",
    "viem": "^2.47.12",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^11.14.0",
    "@types/adm-zip": "^0.5.8",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^22.15.0",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@vitest/coverage-v8": "^4.1.4",
    "prisma": "^7.7.0",
    "testcontainers": "^11.14.0",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "vitest": "^4.1.4",
    "vitest-mock-extended": "^4.0.0"
  }
}
