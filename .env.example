# Privy (for user auth verification)
PRIVY_APP_ID="your-privy-app-id"
PRIVY_APP_SECRET="your-privy-app-secret"

# Admin JWT
ADMIN_JWT_SECRET="min-32-chars-change-this-in-production"

# Blockchain
