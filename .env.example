# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://postgres:password@localhost:5432/wealth_redemption"

# Server
PORT=3001
CORS_ORIGINS="http://localhost:3000,http://localhost:5173,https://redemption-wealthcrypto-fund.vercel.app,https://back-office-wealthcrypto-fund.vercel.app"

# Better Auth
BETTER_AUTH_SECRET="min-32-chars-change-this-in-production"

# Privy (for end-user auth verification)
PRIVY_APP_ID="your-privy-app-id"
PRIVY_APP_SECRET="your-privy-app-secret"

# ⚠️ DEV-ONLY AUTH BYPASS — NEVER set in production.
# When NODE_ENV !== 'production' AND DEV_AUTH_BYPASS === 'true', requireUser lets
# a request authenticate WITHOUT a real Privy token by sending header
# `x-dev-user-id: <privyUserId>` (and optionally `x-dev-user-email: <email>`;
# defaults to <id>@dev.local). This is ONLY for local offline integration/e2e
# tests. NODE_ENV === 'production' hard-disables it regardless of this flag.
# Leave it UNSET everywhere except your local test runner.
# DEV_AUTH_BYPASS="true"

# Blockchain
# Mainnet:  0xafa702c0A2a3a0Cf1bD09435DB61C913cCDe8546  (chain 1)
# Sepolia:  0x3e8c88aA176bE71Ea8124ed278a6347A85d46353  (chain 11155111)
WEALTH_CONTRACT_ADDRESS="0x3e8c88aA176bE71Ea8124ed278a6347A85d46353"
DEV_WALLET_ADDRESS="0x..."
ALCHEMY_RPC_URL="https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY"
# Required. 1 = Ethereum mainnet (production), 11155111 = Sepolia testnet.
# No default: an unset/unsupported value fails fast instead of silently
# using mainnet. Must match ALCHEMY_RPC_URL's network.
ETHEREUM_CHAIN_ID=11155111
ALCHEMY_WEBHOOK_SIGNING_KEY="your-alchemy-webhook-signing-key"

# Price feed (CoinMarketCap for WEALTH/USD, open.er-api.com for USD/IDR)
CMC_API_KEY="your-coinmarketcap-api-key"
WEALTH_CMC_SLUG="wealth-crypto"

# Storage (Cloudflare R2)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_QR_BUCKET_NAME="wealth-qr-codes"
R2_LOGO_BUCKET_NAME="wealth-logos"
# Public base URL for merchant logos (no trailing slash). Use the bucket's
# custom domain in production — the r2.dev dev URL is blocked by some ID ISPs.
# e.g. "https://cdn.wealthcrypto.fund"
R2_LOGO_PUBLIC_URL=""

# Cron (Vercel Cron auth)
# Any strong random string (e.g. `openssl rand -hex 32`). Set the SAME value as
# an env var in the Vercel project — Vercel auto-sends it as
# `Authorization: Bearer <CRON_SECRET>` to /api/cron/* routes. Required in
# production for the stale-pending-redemption sweep to run.
CRON_SECRET="your-cron-secret"

# Seed
INITIAL_OWNER_EMAIL="owner@wealthcrypto.fund"
